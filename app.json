{
  "expo": {
    "name": "Mudra AI",
    "slug": "mudra-ai",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "mudraai",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ai.mudra",
      "infoPlist": {
        "UIBackgroundModes": [
          "remote-notification"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F5F2F1"
      },
      "package": "com.ai.mudra",
      "permissions": [
        "RECEIVE_BOOT_COMPLETED",
        "SCHEDULE_EXACT_ALARM",
        "BILLING"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-iap",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#C8102E"
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-8823796701594878~9835292879",
          "iosAppId": "ca-app-pub-8823796701594878~3593350942"
        }
      ],
      "expo-image",
      "expo-status-bar",
      "expo-asset",
      "expo-audio",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "openAiApiKey": "",
      "adMobBannerUnitId": "ca-app-pub-8823796701594878/9031324540",
      "adMobInterstitialUnitId": "ca-app-pub-8823796701594878/7561809711",
      "adMobBannerUnitIdIOS": "ca-app-pub-8823796701594878/3701876163",
      "adMobInterstitialUnitIdIOS": "ca-app-pub-8823796701594878/3701876163",
      "eas": {
        "projectId": "67808059-d729-41c6-968d-0f0c26532e31"
      }
    },
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#E85C33"
    }
  }
}
